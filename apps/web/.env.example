# Frontend server-side env placeholders (Next.js server runtime only — never
# exposed to the browser; no NEXT_PUBLIC_* values here). All customer data,
# policies, documents, and banking-system responses in this project are
# synthetic and created solely for demonstration.
#
# Sources: apps/web/lib/server/creditops-bff.ts, apps/web/lib/server/cloud-run-auth.ts.
# See docs/DEPLOYMENT_RUNBOOK.md Phase C for exact `vercel env add` commands
# and where each value comes from (mostly `terraform output` from deploy/terraform).

# Upstream Cloud Run API base URL that the BFF proxy forwards allow-listed
# requests to (creditops-bff.ts). Root URL, no trailing slash.
# CREDITOPS_API_URL=https://<cloud-run-api-url>

# Audience for the Google-signed ID token the BFF mints via STS + IAM
# Credentials (cloud-run-auth.ts). Must be an exact HTTPS URL with no path,
# query, or fragment — normally identical to CREDITOPS_API_URL's origin.
# CREDITOPS_API_AUDIENCE=https://<cloud-run-api-url>

# GCP numeric project number (NOT the project ID) — `gcloud projects describe
# <project-id> --format='value(projectNumber)'`.
# GCP_PROJECT_NUMBER=<numeric-project-number>

# The dedicated Vercel->GCP Workload Identity Pool/Provider that
# deploy/terraform/modules/iam/main.tf provisions
# (google_iam_workload_identity_pool.web / .../_provider.web). Must match the
# web_identity_pool_id / web_identity_provider_id Terraform variables exactly.
# GCP_WORKLOAD_IDENTITY_POOL_ID=creditops-web-pool
# GCP_WORKLOAD_IDENTITY_POOL_PROVIDER_ID=creditops-web-oidc

# The impersonated Cloud Run invoker service account
# (terraform output service_account_emails.web_invoker).
# GCP_SERVICE_ACCOUNT_EMAIL=creditops-web-invoker@<gcp-project-id>.iam.gserviceaccount.com

# VERCEL_OIDC_TOKEN is normally injected per-request by the Vercel platform
# (via the x-vercel-oidc-token header) once "OIDC Federation" is enabled in
# the Vercel project's settings — do not set it here. This variable exists
# only so cloud-run-auth.ts has something to read when process.env.VERCEL is
# not "1", i.e. for local testing against a real token you obtained yourself.
# VERCEL_OIDC_TOKEN=<local-testing-only-never-committed>
